PORT=3000
BASE_URL=http://localhost:3000
ADMIN_PIN=2026
APP_FEE_PERCENT=30
BET_VALUE=10
NODE_ENV=development

# Cole aqui o Access Token de TESTE do Mercado Pago.
# Nao coloque esta chave no frontend.
MERCADO_PAGO_ACCESS_TOKEN=TEST-COLE-SEU-ACCESS-TOKEN-AQUI
MERCADO_PAGO_WEBHOOK_SECRET=

# Opcional em desenvolvimento. Quando vazio, o backend retorna PIX simulado.
MERCADO_PAGO_ENABLED=false

# Opcional: URL JSON de uma API/provedor de resultados.
# Formato aceito:
# [{"matchId":"j006","homeScore":2,"awayScore":1,"status":"finalizado"}]
RESULTS_SOURCE_URL=
RESULTS_SYNC_MINUTES=10
